# Required — get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Provider selection (defaults shown)
STT_PROVIDER=groq          # groq | self_hosted
LLM_PROVIDER=groq          # groq | self_hosted
TTS_PROVIDER=edge           # edge | google | self_hosted

# Self-hosted endpoints (only used when *_PROVIDER=self_hosted)
STT_ENDPOINT=http://whisper:9000
LLM_ENDPOINT=http://ollama:11434
TTS_ENDPOINT=http://supertonic:8000

# LLM model override (default varies by provider)
LLM_MODEL=

# Redis URL — set this to enable TTS audio caching (optional)
REDIS_URL=
